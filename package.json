{
  "name": "@depixapp/sdk",
  "version": "1.0.0",
  "description": "Non-custodial Liquid wallet SDK for AI agents — headless Node, local signing, Pix on/off-ramp.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "keywords": [
    "depix",
    "liquid",
    "wallet",
    "non-custodial",
    "pix",
    "bitcoin",
    "agent",
    "mcp",
    "sdk"
  ],
  "homepage": "https://github.com/depixapp/depix-sdk#readme",
  "bugs": {
    "url": "https://github.com/depixapp/depix-sdk/issues"
  },
  "engines": {
    "node": ">=22.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "depix-wallet-mcp": "dist/mcp/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/bake-affiliate.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "SIDESHIFT_AFFILIATE_ID=test-affiliate vitest run",
    "test:watch": "SIDESHIFT_AFFILIATE_ID=test-affiliate vitest",
    "smoke": "node scripts/smoke.mjs",
    "openapi:diff": "node scripts/openapi-diff.mjs",
    "prepublishOnly": "node scripts/check-affiliate-env.mjs && npm run build && DEPIX_SDK_OFFLINE=1 npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depixapp/depix-sdk.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@scure/base": "2.2.0",
    "@vulpemventures/secp256k1-zkp": "3.2.1",
    "boltz-core": "5.0.0",
    "boltz-swaps": "0.0.8",
    "hash-wasm": "4.12.0",
    "liquidjs-lib": "6.0.2-liquid.38",
    "lwk_node": "0.18.0",
    "viem": "2.54.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
