{
  "name": "@depixapp/sdk",
  "version": "0.1.0",
  "description": "Non-custodial Liquid wallet SDK for AI agents — headless Node, local signing, Pix on/off-ramp.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depixapp/depix-sdk.git"
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@scure/base": "2.2.0",
    "@vulpemventures/secp256k1-zkp": "3.2.1",
    "boltz-core": "5.0.0",
    "boltz-swaps": "0.0.8",
    "hash-wasm": "4.12.0",
    "liquidjs-lib": "6.0.2-liquid.38",
    "lwk_node": "0.18.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
